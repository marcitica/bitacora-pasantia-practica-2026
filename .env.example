# Copie este archivo como ".env" (en la raíz del proyecto) y complete sus propios valores.
# NUNCA suba el archivo ".env" real a GitHub — ya está excluido en .gitignore.

# Puerto en el que corre el servidor Express
PORT=3000

# Cadena de conexión a su base de datos MongoDB Atlas (o local)
# Obténgala en https://cloud.mongodb.com -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/bitacora_pasantia?appName=Bitacora

# Clave secreta usada para firmar los tokens JWT.
# Use una cadena larga y aleatoria, distinta por proyecto.
JWT_SECRET=cambie-esto-por-una-clave-larga-y-aleatoria

# Datos del administrador que se crea con "npm run seed"
ADMIN_NOMBRE=Nombre del Administrador
ADMIN_CORREO=admin@correo.com
ADMIN_PASSWORD=defina-una-contraseña-segura
